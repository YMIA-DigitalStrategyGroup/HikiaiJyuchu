    "CreateViewSql": "select `d`.`SHAIN_CODE` AS `SHAIN_CODE`,`d`.`KANRI_NBR` AS `KANRI_NBR`,`d`.`MITSUMORI_NBR` AS `MITSUMORI_NBR`,`d`.`SEQ_NBR` AS `SEQ_NBR`,`d`.`MEISAI_SEQ_NBR` AS `MEISAI_SEQ_NBR`,`d`.`KUBUN` AS `KUBUN`,`d`.`HINBAN` AS `HINBAN`,`d`.`HINMEI` AS `HINMEI`,`d`.`BIKO` AS `BIKO`,`d`.`SURYO` AS `SURYO`,`d`.`TANI` AS `TANI`,`d`.`TANKA` AS `TANKA`,`d`.`KINGAKU` AS `KINGAKU`,`d`.`SHIIRE` AS `SHIIRE`,`d`.`SEIZO_GENKA` AS `SEIZO_GENKA`,`d`.`HANBAIHI` AS `HANBAIHI`,`d`.`JINKENHI` AS `JINKENHI`,`d`.`TOROKU_TIMESTAMP` AS `TOROKU_TIMESTAMP`,`d`.`TOROKUSHA_CODE` AS `TOROKUSHA_CODE`,`d`.`KOSHIN_TIMESTAMP` AS `KOSHIN_TIMESTAMP`,`d`.`KOSHINSHA_CODE` AS `KOSHINSHA_CODE`,`mitsumori_unique`.`EDABAN` AS `EDABAN`,`mitsumori_unique`.`MARGIN_FLAG` AS `MARGIN_FLAG`,`mitsumori_unique`.`MARGIN_RITSU1` AS `MARGIN_RITSU1`,`mitsumori_unique`.`MARGIN_RITSU2` AS `MARGIN_RITSU2`,`mitsumori_unique`.`MARGIN_RITSU3` AS `MARGIN_RITSU3`,`mitsumori_unique`.`KISHU` AS `KISHU`,`mitsumori_unique`.`KIBAN` AS `KIBAN`,`mitsumori_unique`.`KENMEI` AS `KENMEI`,`mitsumori_unique`.`NONYUSAKI` AS `NONYUSAKI`,truncate((case when (`mitsumori_unique`.`MARGIN_FLAG` = 3) then (((`d`.`KINGAKU` * (1 + (`mitsumori_unique`.`MARGIN_RITSU1` / 100.0))) * (1 + (`mitsumori_unique`.`MARGIN_RITSU2` / 100.0))) * (1 + (`mitsumori_unique`.`MARGIN_RITSU3` / 100.0))) when (`mitsumori_unique`.`MARGIN_FLAG` = 2) then ((`d`.`KINGAKU` * (1 + (`mitsumori_unique`.`MARGIN_RITSU1` / 100.0))) * (1 + (`mitsumori_unique`.`MARGIN_RITSU2` / 100.0))) when (`mitsumori_unique`.`MARGIN_FLAG` = 1) then (`d`.`KINGAKU` * (1 + (`mitsumori_unique`.`MARGIN_RITSU1` / 100.0))) else `d`.`KINGAKU` end),-(3)) AS `MARGIN_KOMI_KINGAKU` from ((select `tmitsumori`.`MITSUMORI_NBR` AS `MITSUMORI_NBR`,`tmitsumori`.`EDABAN` AS `EDABAN`,max(`tmitsumori`.`SEQ_NBR`) AS `MAX_SEQ_NBR`,`tmitsumori`.`MARGIN_FLAG` AS `MARGIN_FLAG`,`tmitsumori`.`MARGIN_RITSU1` AS `MARGIN_RITSU1`,`tmitsumori`.`MARGIN_RITSU2` AS `MARGIN_RITSU2`,`tmitsumori`.`MARGIN_RITSU3` AS `MARGIN_RITSU3`,`tmitsumori`.`KISHU` AS `KISHU`,`tmitsumori`.`KIBAN` AS `KIBAN`,`tmitsumori`.`KENMEI` AS `KENMEI`,`tmitsumori`.`NONYUSAKI` AS `NONYUSAKI` from `tmitsumori` group by `tmitsumori`.`MITSUMORI_NBR`,`tmitsumori`.`EDABAN`,`tmitsumori`.`MARGIN_FLAG`,`tmitsumori`.`MARGIN_RITSU1`,`tmitsumori`.`MARGIN_RITSU2`,`tmitsumori`.`MARGIN_RITSU3`) `mitsumori_unique` left join `tmitsumorim` `d` on(((`mitsumori_unique`.`MITSUMORI_NBR` = `d`.`MITSUMORI_NBR`) and (`mitsumori_unique`.`MAX_SEQ_NBR` = `d`.`SEQ_NBR`))))",
